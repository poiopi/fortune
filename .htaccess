RewriteEngine On
RewriteBase /

# http → https リダイレクト
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 旧WordPressのURLを全部トップにリダイレクト
RewriteRule ^index\.php/.*$ / [R=301,L]

# .php拡張子を省略したURLへ301リダイレクト（index.phpは除外）
# GET/HEADのみを対象とする。301リダイレクトはPOSTボディを保持しないため、
# POSTフォーム（sansei.php等）を持つページで.php付きURLへ直接POSTされた場合に
# データが失われる問題があった（2026-07-06 Step5-B調査で発見）。
RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$
RewriteCond %{THE_REQUEST} \s/(?!index\.php)([^?\s]+)\.php[?\s] [NC]
RewriteRule ^ /%1 [R=301,L]

# 拡張子なしのURLで対応する.phpファイルを内部的に呼び出す
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^.]+)$ $1.php [L]