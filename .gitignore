# SFTP/FTP credentials
.vscode/sftp.json
**/.htpasswd

# Claude Code local settings (machine-specific, not for sharing)
.claude/settings.local.json

# Generic credential file patterns (defense in depth)
.env
.env.*
*.pem
*.key
id_rsa*
**/sftp.json
**/*credentials*
**/*secrets*

# OS/editor junk
.DS_Store
Thumbs.db

# Local notes (not for public repo)
CLAUDE.md
ARCHITECTURE.md
DESIGN.md
SEO.md
COMPONENTS.md
CHANGELOG.md
DEVELOPMENT_RULES.md
DEPLOY_CHECKLIST.md

# Internal design docs / implementation plans (blanket rule so new
# internal .md files are protected automatically, mirroring the
# .vscode/sftp.json ignore list's *.md / README* coverage).
# Scoped to markdown by extension (not a directory-wide docs/ ignore)
# so a future docs/public/ with non-.md assets stays trackable.
*.md
README*

# Dev-only test/tooling assets (Golden Master scripts and fixtures).
# Not part of the public site; not covered by the *.md rule above
# since these are .js/.php.
tests/
